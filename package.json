{
  "name": "openrv-web",
  "version": "0.1.0",
  "description": "Web-based VFX image/sequence viewer inspired by OpenRV",
  "author": "Alex Kanunnikov <lifeart92@gmail.com>",
  "homepage": "https://lifeart.github.io/openrv-web",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifeart/openrv-web.git"
  },
  "bugs": {
    "url": "https://github.com/lifeart/openrv-web/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:ui": "playwright test --ui",
    "docs:api": "typedoc",
    "docs:generate": "npx tsx scripts/docs/generate-all.ts",
    "docs:check": "npx tsx scripts/docs/generate-all.ts --check",
    "docs:check-wiring": "npx tsx scripts/docs/check-wiring.ts",
    "docs:dev": "pnpm docs:generate && pnpm docs:api && vitepress dev docs",
    "docs:build": "pnpm docs:generate && pnpm docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "screenshots": "playwright test --project=screenshots",
    "screenshots:update": "playwright test --project=screenshots --update-snapshots",
    "docs:ai-generate": "npx tsx docs/scripts/ai-generate.ts",
    "docs:fact-check": "npx tsx docs/scripts/fact-check.ts --all",
    "docs:validate": "npx tsx docs/scripts/validate-output.ts --all",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test:gpu": "vitest run --config vitest.browser.config.ts",
    "test:gpu:watch": "vitest watch --config vitest.browser.config.ts",
    "test:gpu:ui": "vitest --config vitest.browser.config.ts --ui",
    "format": "prettier --write \"src/**/*.ts\" \"*.{ts,mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{ts,mjs,json}\"",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@jsquash/jxl": "^1.3.0",
    "gl-matrix": "^3.4.3",
    "gto-js": "1.0.0",
    "libheif-js": "^1.19.8",
    "mediabunny": "^1.38.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.40.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "vfx",
    "openrv",
    "openrv-alternative",
    "image-viewer",
    "sequence-viewer",
    "video-player",
    "exr-viewer",
    "dailies-review",
    "color-grading",
    "color-correction",
    "cdl",
    "lut",
    "3d-lut",
    "histogram",
    "waveform",
    "vectorscope",
    "gto",
    "rv-session",
    "webgl",
    "annotations",
    "frame-accurate",
    "stereo-3d",
    "post-production",
    "film-production",
    "aswf"
  ],
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ]
  },
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
