{
  "name": "openrv-web",
  "version": "0.1.0",
  "description": "Web-based VFX image/sequence viewer inspired by OpenRV",
  "author": "Alex Kanunnikov <lifeart92@gmail.com>",
  "homepage": "https://lifeart.github.io/openrv-web",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lifeart/openrv-web.git"
  },
  "bugs": {
    "url": "https://github.com/lifeart/openrv-web/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:ui": "playwright test --ui",
    "docs:api": "typedoc",
    "docs:generate": "npx tsx scripts/docs/generate-all.ts",
    "docs:check": "npx tsx scripts/docs/generate-all.ts --check",
    "docs:dev": "pnpm docs:generate && pnpm docs:api && vitepress dev docs",
    "docs:build": "pnpm docs:generate && pnpm docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "screenshots": "playwright test --project=screenshots",
    "screenshots:update": "playwright test --project=screenshots --update-snapshots",
    "docs:ai-generate": "npx tsx docs/scripts/ai-generate.ts",
    "docs:fact-check": "npx tsx docs/scripts/fact-check.ts --all",
    "docs:validate": "npx tsx docs/scripts/validate-output.ts --all"
  },
  "dependencies": {
    "@jsquash/jxl": "^1.3.0",
    "gl-matrix": "^3.4.3",
    "gto-js": "1.0.0",
    "libheif-js": "^1.19.8",
    "mediabunny": "^1.28.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@playwright/test": "^1.40.0",
    "@vitest/coverage-v8": "^1.2.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitepress": "^1.6.4",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "vfx",
    "openrv",
    "openrv-alternative",
    "image-viewer",
    "sequence-viewer",
    "video-player",
    "exr-viewer",
    "dailies-review",
    "color-grading",
    "color-correction",
    "cdl",
    "lut",
    "3d-lut",
    "histogram",
    "waveform",
    "vectorscope",
    "gto",
    "rv-session",
    "webgl",
    "annotations",
    "frame-accurate",
    "stereo-3d",
    "post-production",
    "film-production",
    "aswf"
  ],
  "license": "MIT"
}
